# URL del servidor Node (mismo puerto que planificación, ej. 3002)
EXPO_PUBLIC_API_URL=http://192.168.0.10:3002

# Key de Maps SDK for Android (Google Cloud Console → credenciales → API key con Maps SDK for Android habilitado)
GOOGLE_MAPS_ANDROID_KEY=tu_clave_aqui

# iOS: Maps SDK + Navigation SDK (misma key o una con bundle id com.r14.seguimiento). Si no definís, se usa GOOGLE_MAPS_ANDROID_KEY solo en dev.
GOOGLE_MAPS_IOS_KEY=tu_clave_ios_aqui
